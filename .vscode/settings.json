{
  "python.defaultInterpreterPath": "/root/miniconda3/envs/llm_test/bin/python3.10",
  "python.languageServer": "Pylance",
  "python.analysis.typeCheckingMode": "off",
  "python.analysis.diagnosticMode": "openFilesOnly",
  "python.analysis.extraPaths": [
    "${workspaceFolder}",
    "${workspaceFolder}/adaptations",
    "${workspaceFolder}/kernels",
    "${workspaceFolder}/kernels/src",
    "${workspaceFolder}/scripts",
    "${workspaceFolder}/.venv/lib/python3.10/site-packages"
  ],
  "python.analysis.autoImportCompletions": true,
  "python.analysis.indexing": true,
  "python.analysis.useLibraryCodeForTypes": true,
  "python.analysis.autoSearchPaths": true,
  "python.analysis.stubPath": "${workspaceFolder}",
  "python.terminal.activateEnvironment": true,
  "python.autoComplete.extraPaths": [
    "${workspaceFolder}",
    "${workspaceFolder}/adaptations",
    "${workspaceFolder}/kernels"
  ],
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    ".pytest_cache": true,
    "kernel_meta": true,
    ".uv-cache": true
  }
}
